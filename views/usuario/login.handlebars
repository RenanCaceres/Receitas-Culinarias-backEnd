<div style="max-width:400px; margin: 60px auto;">
    <div class="card">
        <h2 style="margin-bottom:20px; text-align:center;">🔐 Login</h2>
        {{#if erro}}
        <div class="alert-erro">{{erro}}</div>
        {{/if}}
        <form action="/login" method="post">
            <div class="form-group">
                <label for="login">Login</label>
                <input type="text" id="login" name="login" required placeholder="Seu login">
            </div>
            <div class="form-group">
                <label for="senha">Senha</label>
                <input type="password" id="senha" name="senha" required placeholder="Sua senha">
            </div>
            <input type="submit" value="Entrar" class="btn btn-primary" style="width:100%;">
        </form>
    </div>
</div>
