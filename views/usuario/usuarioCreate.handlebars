<div class="page-title">
    <h2>➕ Novo Usuário</h2>
    <a href="/usuarioList" class="btn btn-secondary">← Voltar</a>
</div>
<div class="card" style="max-width:500px;">
    <form action="/usuarioCreate" method="post">
        <div class="form-group">
            <label>Nome completo</label>
            <input type="text" name="nome" required placeholder="Nome do usuário">
        </div>
        <div class="form-group">
            <label>Login</label>
            <input type="text" name="login" required placeholder="Login de acesso">
        </div>
        <div class="form-group">
            <label>Senha</label>
            <input type="password" name="senha" required placeholder="Senha">
        </div>
        <div class="form-group">
            <label>Tipo</label>
            <select name="tipo">
                <option value="2">Aluno</option>
                <option value="1">Administrador</option>
            </select>
        </div>
        <input type="submit" value="Cadastrar" class="btn btn-primary">
    </form>
</div>
