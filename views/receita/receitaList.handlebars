<div class="page-title">
    <h2>📋 {{#if isAdmin}}Todas as Receitas{{else}}Minhas Receitas{{/if}}</h2>
    <a href="/receitaCreate" class="btn btn-primary">➕ Nova Receita</a>
</div>

{{#if receitas.length}}
<table>
    <thead>
        <tr>
            <th>Receita</th>
            <th>Categorias</th>
            <th>Responsáveis</th>
            <th>Link</th>
            <th>Ações</th>
        </tr>
    </thead>
    <tbody>
        {{#each receitas}}
        <tr>
            <td>
                <strong>{{nome}}</strong>
                <div style="font-size:0.8rem;color:var(--gray-text);margin-top:2px;">{{descricao}}</div>
            </td>
            <td>
                {{#each Categorias}}<span class="badge">{{nome}}</span>{{/each}}
            </td>
            <td>
                {{#each Responsaveis}}<span class="badge">{{nome}}</span>{{/each}}
            </td>
            <td>
                {{#if linkExterno}}
                <a href="{{linkExterno}}" target="_blank" class="btn btn-secondary" style="font-size:0.8rem;padding:7px 12px;">🔗 Ver</a>
                {{/if}}
            </td>
            <td>
                <div style="display:flex;gap:8px;align-items:center;">
                    <a href="/receitaUpdate/{{id}}" class="btn btn-secondary" style="padding:8px 12px;">✏️</a>
                    <a href="/receitaDelete/{{id}}" class="btn btn-danger" style="padding:8px 12px;"
                       onclick="return confirm('Excluir a receita {{nome}}?')">🗑️</a>
                </div>
            </td>
        </tr>
        {{/each}}
    </tbody>
</table>
{{else}}
<div class="card" style="text-align:center;padding:60px 40px;">
    <div style="font-size:3rem;margin-bottom:16px;">📋</div>
    <h3 style="font-family:'Playfair Display',serif;font-size:1.3rem;color:var(--charcoal);margin-bottom:10px;">Nenhuma receita cadastrada</h3>
    <p style="color:var(--gray-text);margin-bottom:24px;">Comece cadastrando sua primeira criação culinária!</p>
    <a href="/receitaCreate" class="btn btn-primary">➕ Cadastrar primeira receita</a>
</div>
{{/if}}
