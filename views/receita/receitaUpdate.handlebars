<div class="page-title">
    <h2>✏️ Editar Receita</h2>
    <a href="/receitaList" class="btn btn-secondary">← Voltar</a>
</div>
<div class="card" style="max-width:700px;">
    <form action="/receitaUpdate" method="post">
        <input type="hidden" name="id" value="{{receita.id}}">

        <div class="form-group">
            <label>Nome da Receita</label>
            <input type="text" name="nome" value="{{receita.nome}}" required>
        </div>
        <div class="form-group">
            <label>Descrição</label>
            <textarea name="descricao" required>{{receita.descricao}}</textarea>
        </div>
        <div class="form-group">
            <label>Ingredientes</label>
            <textarea name="ingredientes">{{receita.ingredientes}}</textarea>
        </div>
        <div class="form-group">
            <label>Modo de preparo</label>
            <textarea name="preparo">{{receita.preparo}}</textarea>
        </div>
        <div class="form-group">
            <label>Link Externo</label>
            <input type="url" name="linkExterno" value="{{receita.linkExterno}}">
        </div>

        <div class="form-group">
            <label>Categorias</label>
            <div style="display:flex; flex-wrap:wrap; gap:10px; padding:8px; border:1px solid #ccc; border-radius:4px; background:white;">
                {{#each categorias}}
                <label style="display:flex; align-items:center; gap:4px; cursor:pointer;">
                    <input type="checkbox" name="categorias" value="{{id}}" {{#if selecionada}}checked{{/if}}> {{nome}}
                </label>
                {{/each}}
            </div>
        </div>

        <div class="form-group">
            <label>Responsáveis</label>
            <div style="display:flex; flex-wrap:wrap; gap:10px; padding:8px; border:1px solid #ccc; border-radius:4px; background:white;">
                {{#each alunos}}
                <label style="display:flex; align-items:center; gap:4px; cursor:pointer;">
                    <input type="checkbox" name="responsaveis" value="{{id}}" {{#if selecionado}}checked{{/if}}> {{nome}} ({{login}})
                </label>
                {{/each}}
            </div>
        </div>

        <input type="submit" value="💾 Salvar Alterações" class="btn btn-primary">
    </form>
</div>
