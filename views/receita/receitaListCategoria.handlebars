<div class="page-title">
    <h2>🏷️ Receitas por Categoria</h2>
</div>

<div class="card" style="margin-bottom:24px;">
    <form action="/receitasPorCategoria" method="get" style="display:flex; gap:12px; align-items:flex-end; flex-wrap:wrap;">
        <div class="form-group" style="flex:1; min-width:200px; margin:0;">
            <label>Escolha uma categoria:</label>
            <select name="categoriaId" onchange="this.form.submit()">
                <option value="">-- Selecione --</option>
                {{#each Categorias}}
                <option value="{{id}}" {{#if selecionada}}selected{{/if}}>{{nome}}</option>
                {{/each}}
            </select>
        </div>
    </form>
</div>

{{#if categoriaSelecionada}}
<h3 style="margin-bottom:16px;">
    Receitas em <span style="color:#c0392b;">{{nomeCategoriaSelecionada}}</span>
    ({{receitas.length}})
</h3>
{{/if}}

{{#if receitas.length}}
<div class="receita-grid">
    {{#each receitas}}
    <div class="card">
        <h3 style="margin-bottom:8px; color:#c0392b;">{{nome}}</h3>
        <p style="color:#555; margin-bottom:12px; font-size:0.95rem;">{{descricao}}</p>
        <div style="margin-bottom:8px;">
            {{#each Categorias}}
            <span class="badge">{{nome}}</span>
            {{/each}}
        </div>
        <p style="font-size:0.85rem; color:#888;">
            👨‍🍳
            {{#each Responsaveis}}{{nome}}{{#unless @last}}, {{/unless}}{{/each}}
        </p>
        {{#if linkExterno}}
        <br>
        <a href="{{linkExterno}}" target="_blank" class="btn btn-primary" style="font-size:0.85rem;">🔗 Ver receita</a>
        {{/if}}
    </div>
    {{/each}}
</div>
{{else}}
{{#if categoriaSelecionada}}
<div class="card" style="text-align:center; color:#666;">
    <p>Nenhuma receita nessa categoria ainda.</p>
</div>
{{/if}}
{{/if}}
