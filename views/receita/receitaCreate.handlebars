<div class="page-title">
    <h2>➕ Nova Receita</h2>
    <a href="/receitaList" class="btn btn-secondary">← Voltar</a>
</div>

<div class="card" style="max-width:700px;">
    <p style="font-family:'Playfair Display',serif;font-size:1.05rem;font-weight:600;color:var(--charcoal);margin-bottom:20px;padding-bottom:10px;border-bottom:2px solid var(--rust);display:inline-block;">Informações Básicas</p>
    <form action="/receitaCreate" method="post">
        <div class="form-group">
            <label>Nome da Receita</label>
            <input type="text" name="nome" required placeholder="Ex: Bolo de Cenoura com Calda de Chocolate">
        </div>
        <div class="form-group">
            <label>Descrição</label>
            <textarea name="descricao" required placeholder="Descreva brevemente a receita..."></textarea>
        </div>
        <div class="form-group">
            <label>Ingredientes</label>
            <textarea name="ingredientes" placeholder="Liste os ingredientes principais..."></textarea>
        </div>
        <div class="form-group">
            <label>Modo de Preparo</label>
            <textarea name="preparo" placeholder="Descreva o modo de preparo..."></textarea>
        </div>
        <div class="form-group">
            <label>Link Externo <small>(opcional)</small></label>
            <input type="url" name="linkExterno" placeholder="https://...">
        </div>

        <hr style="border:none;border-top:1px solid var(--border);margin:24px 0;">
        <p style="font-family:'Playfair Display',serif;font-size:1.05rem;font-weight:600;color:var(--charcoal);margin-bottom:20px;padding-bottom:10px;border-bottom:2px solid var(--rust);display:inline-block;">Classificação</p>

        <div class="form-group">
            <label>Categorias <small>(selecione uma ou mais)</small></label>
            <div style="display:flex;flex-wrap:wrap;gap:10px;padding:12px;border:1.5px solid var(--border);border-radius:10px;background:white;">
                {{#each categorias}}
                <label style="display:flex;align-items:center;gap:8px;padding:8px 14px;border-radius:8px;cursor:pointer;border:1.5px solid var(--border);background:var(--cream);font-size:0.88rem;font-weight:500;transition:all 0.15s;color:var(--charcoal);">
                    <input type="checkbox" name="categorias" value="{{id}}"> {{nome}}
                </label>
                {{/each}}
            </div>
        </div>

        <div class="form-group">
            <label>Coautores / Responsáveis <small>(além de você)</small></label>
            <div style="display:flex;flex-wrap:wrap;gap:10px;padding:12px;border:1.5px solid var(--border);border-radius:10px;background:white;">
                {{#each alunos}}
                <label style="display:flex;align-items:center;gap:8px;padding:8px 14px;border-radius:8px;cursor:pointer;border:1.5px solid var(--border);background:var(--cream);font-size:0.88rem;font-weight:500;color:var(--charcoal);">
                    <input type="checkbox" name="responsaveis" value="{{id}}"> {{nome}} <span style="color:var(--gray-text);font-size:0.8rem;">({{login}})</span>
                </label>
                {{/each}}
            </div>
        </div>

        <input type="submit" value="📥 Cadastrar Receita" class="btn btn-primary" style="width:100%;text-align:center;padding:14px;">
    </form>
</div>
