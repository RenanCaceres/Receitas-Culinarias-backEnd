<div class="page-title">
    <h2>💬 Comentários</h2>
    <a href="/comentarioCreate" class="btn btn-primary">➕ Novo Comentário</a>
</div>

{{#if comentarios.length}}
    {{#each comentarios}}
    <div class="card">
        <h3 style="color:#c0392b; margin-bottom:4px;">{{titulo}}</h3>
        <p style="color:#777; margin-bottom:8px;">Por {{autor}}</p>
        <p>{{texto}}</p>
    </div>
    {{/each}}
{{else}}
<div class="card" style="text-align:center; color:#666;">
    <p>Nenhum comentário cadastrado.</p>
</div>
{{/if}}
