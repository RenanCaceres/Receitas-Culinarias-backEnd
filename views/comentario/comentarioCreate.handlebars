<div class="page-title">
    <h2>💬 Novo Comentário</h2>
    <a href="/comentarioList" class="btn btn-secondary">← Voltar</a>
</div>

<div class="card" style="max-width:700px;">
    <form action="/comentarioCreate" method="post">
        <div class="form-group">
            <label>Título</label>
            <input type="text" name="titulo" required placeholder="Título do comentário">
        </div>
        <div class="form-group">
            <label>Autor</label>
            <input type="text" name="autor" value="{{usuarioLogin}}" required>
        </div>
        <div class="form-group">
            <label>Comentário</label>
            <textarea name="texto" required placeholder="Digite seu comentário..."></textarea>
        </div>
        <input type="submit" value="Salvar Comentário" class="btn btn-primary">
    </form>
</div>
